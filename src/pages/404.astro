---
import Base from '../layouts/Base.astro';
---
<Base title="404 — Page not found" description="Page not found on Compressly." canonical="/404" keywords="404, page not found">
  <section class="section">
    <div class="container" style="max-width:720px; text-align:center;">
      <h1 class="display-xl" style="margin-bottom:12px;">404 — Page not found</h1>
      <p class="body-lg" style="color:var(--body); margin-bottom:20px;">Sorry, we couldn't find the page you're looking for. It may have been moved or deleted.</p>
      <a href="/" class="btn-primary">Go to Home</a>
    </div>
  </section>
</Base>
