---
import Base from '../layouts/Base.astro';
---
<Base title="500 — Server error" description="Server error on Compressly." canonical="/500" keywords="500, server error">
  <section class="section">
    <div class="container" style="max-width:720px; text-align:center;">
      <h1 class="display-xl" style="margin-bottom:12px;">500 — Server error</h1>
      <p class="body-lg" style="color:var(--body); margin-bottom:20px;">Something went wrong on our side. Please try again in a few moments.</p>
      <a href="/" class="btn-primary">Go to Home</a>
    </div>
  </section>
</Base>
