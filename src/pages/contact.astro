---
import Base from '../layouts/Base.astro';
---
<Base
  title="Contact Compressly — Get in touch"
  description="Contact Compressly for support, feedback, or questions about compressing PDFs and images."
  canonical="/contact"
  keywords="contact, compressly contact, support"
>

<section class="section">
  <div class="container" style="max-width:720px;">
    <p class="mono-eyebrow">Contact</p>
    <h1 class="heading-lg" style="margin-bottom:12px;">Get in touch</h1>
    <p class="body-lg" style="color:var(--body); margin-bottom:16px;">
      For support, feedback, or press inquiries, email us at <a href="mailto:hello@compressly.app">hello@compressly.app</a>.
      We aim to respond within 1–3 business days.
    </p>

    <div class="feature-card">
      <p class="label-sm" style="margin-bottom:8px;">General inquiries</p>
      <p class="body-md" style="color:var(--body);">Use the email above for questions about features, privacy, or partnership requests.</p>
    </div>
  </div>
</section>

</Base>
