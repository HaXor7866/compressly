</Base>

<style>
.tool-grid { grid-template-columns: 1fr 300px; }
@media (max-width: 900px) { 
  .tool-grid { grid-template-columns: 1fr !important; gap: 24px; }
  .ad-slot-sidebar { width: 100% !important; }
}
@media (max-width: 768px) {
  .tool-grid { gap: 20px; }
}
@media (max-width: 640px) {
  .tool-grid { gap: 16px; }
  .ad-slot-sidebar { height: 100px !important; }
}

/* FAQ */
.faq-item { border-bottom: 1px solid var(--hairline); }
.faq-q {
  width: 100%; background: none; border: none; cursor: pointer;
  text-align: left; padding: 18px 0;
  font-size: 15px; font-weight: 500; color: var(--ink);
  font-family: var(--font-sans);
  display: flex; justify-content: space-between; align-items: center;
}
.faq-q::after { content: '+'; font-size: 20px; color: var(--mute); transition: transform 0.2s; }
.faq-q.open::after { content: '−'; }
.faq-a { display: none; padding: 0 0 16px; color: var(--body); font-size: 14px; line-height: 22px; }
.faq-a.open { display: block; }
</style>

<script>
// ── State ──
let files = [];
let results = [];

// ── DOM refs ──
const uploadZone  = document.getElementById('uploadZone');
const fileInput   = document.getElementById('fileInput');
const settingsPanel = document.getElementById('settingsPanel');
const qualitySlider = document.getElementById('qualitySlider');
const qualityValue  = document.getElementById('qualityValue');
const compressBtn   = document.getElementById('compressBtn');
const clearBtn      = document.getElementById('clearBtn');
const fileCount     = document.getElementById('fileCount');
const resultsList   = document.getElementById('resultsList');
const downloadAllWrap = document.getElementById('downloadAllWrap');
const downloadAllBtn  = document.getElementById('downloadAllBtn');

// ── Quality slider ──
qualitySlider.addEventListener('input', () => {
  qualityValue.textContent = qualitySlider.value + '%';
});

// ── Drag & drop ──
uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('drag-over'); });
uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('drag-over'));
uploadZone.addEventListener('drop', e => {
  e.preventDefault(); uploadZone.classList.remove('drag-over');
  handleFiles([...e.dataTransfer.files]);
});
uploadZone.addEventListener('click', e => {
  if (e.target === uploadZone || e.target.id === 'uploadZone') fileInput.click();
});
fileInput.addEventListener('change', () => handleFiles([...fileInput.files]));

function handleFiles(newFiles) {
  const valid = newFiles.filter(f => ['image/jpeg','image/png','image/webp'].includes(f.type));
  if (!valid.length) return alert('Please select JPG, PNG, or WEBP files.');
  files = [...files, ...valid];
  fileCount.textContent = `${files.length} file${files.length>1?'s':''} selected`;
  settingsPanel.removeAttribute('hidden');
  document.getElementById('uploadPrompt').querySelector('p.heading-md').textContent = `${files.length} image${files.length>1?'s':''} ready`;
}

// ── Compress ──
compressBtn.addEventListener('click', async () => {
  if (!files.length) return;
  results = [];
  resultsList.innerHTML = '';
  downloadAllWrap.setAttribute('hidden', '');
  compressBtn.disabled = true;
  compressBtn.innerHTML = '<span class="spinner"></span> Compressing…';

  const quality = parseInt(qualitySlider.value) / 100;

  for (const file of files) {
    const row = createResultRow(file.name, formatBytes(file.size));
    resultsList.appendChild(row.el);
    try {
      const blob = await compressImage(file, quality);
      const saving = Math.round((1 - blob.size / file.size) * 100);
      row.update(formatBytes(blob.size), saving, blob, file.name);
      results.push({ blob, name: file.name, saving });
    } catch(e) {
      row.error();
    }
  }

  compressBtn.disabled = false;
  compressBtn.innerHTML = '⚡ Compress All';
  if (results.length > 1) downloadAllWrap.removeAttribute('hidden');
});

function compressImage(file, quality) {
  return new Promise((resolve, reject) => {
    const img = new Image();
    const url = URL.createObjectURL(file);
    img.onload = () => {
      const canvas = document.createElement('canvas');
      canvas.width = img.naturalWidth;
      canvas.height = img.naturalHeight;
      const ctx = canvas.getContext('2d');
      ctx.drawImage(img, 0, 0);
      const mimeType = file.type === 'image/png' ? 'image/webp' : file.type === 'image/webp' ? 'image/webp' : 'image/jpeg';
      canvas.toBlob(blob => {
        URL.revokeObjectURL(url);
        if (blob) resolve(blob); else reject(new Error('Compression failed'));
      }, mimeType, quality);
    };
    img.onerror = reject;
    img.src = url;
  });
}

function createResultRow(name, origSize) {
  const el = document.createElement('div');
  el.className = 'result-row';
  el.innerHTML = `
    <div style="flex:1; min-width:0;">
      <p class="label-sm" style="white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">${escHtml(name)}</p>
      <div style="display:flex; gap:6px; margin-top:4px; flex-wrap:wrap; align-items:center;">
        <span class="size-badge">${origSize}</span>
        <span style="color:var(--mute); font-size:12px;">→</span>
        <span class="size-badge compressedSize">…</span>
        <span class="savingBadge" style="display:none;"></span>
      </div>
    </div>
    <div class="actionArea"><span class="spinner"></span></div>
  `;
  return {
    el,
    update(newSize, saving, blob, origName) {
      el.querySelector('.compressedSize').textContent = newSize;
      const badge = el.querySelector('.savingBadge');
      badge.style.display = '';
      badge.className = 'size-badge saved';
      badge.textContent = saving > 0 ? `-${saving}%` : 'Optimized';
      const action = el.querySelector('.actionArea');
      const extension = blob.type.split('/')[1] || 'bin';
      const safeName = origName.replace(/\.[^/.]+$/, '');
      action.innerHTML = `<button class="btn-ghost-sm" onclick="downloadBlob(this)" 
        data-url="${URL.createObjectURL(blob)}" 
        data-name="compressed_${safeName}.${extension}">⬇ Save</button>`;
    },
    error() {
      el.querySelector('.actionArea').innerHTML = '<span style="color:var(--error); font-size:12px;">Failed</span>';
    }
  };
}

window.downloadBlob = function(btn) {
  const a = document.createElement('a');
  a.href = btn.dataset.url;
  a.download = btn.dataset.name;
  a.click();
};

// ── Download All ──
downloadAllBtn.addEventListener('click', async () => {
  for (const r of results) {
    const a = document.createElement('a');
    a.href = URL.createObjectURL(r.blob);
    a.download = 'compressed_' + r.name;
    a.click();
    await new Promise(r => setTimeout(r, 200));
  }
});

// ── Clear ──
clearBtn.addEventListener('click', () => {
  files = []; results = [];
  fileInput.value = '';
  resultsList.innerHTML = '';
  settingsPanel.setAttribute('hidden', '');
  downloadAllWrap.setAttribute('hidden', '');
  document.getElementById('uploadPrompt').querySelector('p.heading-md').textContent = 'Drop images here';
  fileCount.textContent = '';
});

// ── Utils ──
function formatBytes(bytes) {
  if (bytes < 1024) return bytes + ' B';
  if (bytes < 1024 * 1024) return (bytes/1024).toFixed(1) + ' KB';
  return (bytes/(1024*1024)).toFixed(2) + ' MB';
}
function escHtml(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

// ── FAQ accordion ──
document.querySelectorAll('.faq-q').forEach(btn => {
  btn.addEventListener('click', () => {
    const ans = btn.nextElementSibling;
    btn.classList.toggle('open');
    ans.classList.toggle('open');
  });
});
</script>
