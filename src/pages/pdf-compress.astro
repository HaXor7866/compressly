---
import Base from '../layouts/Base.astro';
---
<Base
  title="Free PDF Compressor Online – Reduce PDF Size | Compressly"
  description="Compress PDF files online for free. Reduce PDF file size by compressing embedded images. No upload required – runs in your browser."
  canonical="/pdf-compress"
  schema={{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Compress PDF Online",
  "url": "https://compresspdfonline.com/pdf-compress",
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "Web",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
}}
>

<!-- ── HERO ── -->
<section class="hero-section" style="padding:80px 0 64px;">
  <div class="hero-gradient"></div>
  <div class="container" style="position:relative; z-index:1; text-align:center;">
    <p class="mono-eyebrow" style="margin-bottom:16px;">Browser-based · No server upload</p>
    <h1 class="display-xl" style="margin-bottom:16px; max-width:700px; margin-left:auto; margin-right:auto;">
      Compress PDF Online for Free
    </h1>
    <p class="body-lg" style="color:var(--body); max-width:500px; margin:0 auto 32px;">
      Reduce PDF size by compressing embedded images. Works offline in your browser with no upload required.
    </p>
    <a href="#pdf-tool" class="btn-primary" style="font-size:15px; padding:10px 22px;">
      Compress PDF ↓
    </a>
  </div>
</section>

<!-- ── AD TOP ── -->
<div class="container" style="margin-bottom:32px;">
  <div class="ad-slot ad-slot-banner">
    <span>Advertisement · AdSense banner</span>
  </div>
</div>

<!-- ── TOOL ── -->
<section id="pdf-tool" class="section-sm">
  <div class="container">
    <div style="display:grid; grid-template-columns:1fr 300px; gap:32px;" class="tool-grid">

      <!-- LEFT -->
      <div>
        <!-- Step 1: Upload -->
        <div class="upload-zone" id="pdfUploadZone">
          <input type="file" id="pdfFileInput" accept="application/pdf" />
          <div>
            <div style="font-size:48px; margin-bottom:12px;">📄</div>
            <p class="heading-md" style="margin-bottom:8px;">Drop a PDF here</p>
            <p class="body-md" style="color:var(--mute); margin-bottom:16px;">PDF files only</p>
            <button type="button" class="btn-primary" onclick="document.getElementById('pdfFileInput').click()">
              Choose PDF
            </button>
          </div>
        </div>

        <!-- Step 2: Settings (hidden until file chosen) -->
        <div class="feature-card" id="pdfSettings" hidden style="margin-top:16px;">
          <div style="display:flex; align-items:center; gap:12px; margin-bottom:16px; flex-wrap:wrap;">
            <div>
              <p class="label-sm" id="pdfFileName"></p>
              <p class="body-sm" style="color:var(--mute);" id="pdfOrigSize"></p>
            </div>
            <span class="size-badge" id="pdfOrigBadge" style="margin-left:auto;"></span>
          </div>

          <div class="slider-wrap" style="margin-bottom:16px;">
            <label>
              <span>Image Quality Inside PDF</span>
              <span id="pdfQualityValue" style="font-family:var(--font-mono); color:var(--link);">60%</span>
            </label>
            <input type="range" id="pdfQualitySlider" min="10" max="95" value="60" />
            <div style="display:flex; justify-content:space-between;">
              <span style="color:var(--mute); font-size:12px;">Smaller PDF</span>
              <span style="color:var(--mute); font-size:12px;">Better quality</span>
            </div>
          </div>

          <!-- Progress -->
          <div id="pdfProgress" hidden style="margin-bottom:16px;">
            <div class="progress">
              <div class="progress-bar" id="pdfProgressBar" style="width:0%"></div>
            </div>
            <p class="body-sm" style="color:var(--mute); margin-top:8px;" id="pdfProgressText">Processing…</p>
          </div>

          <div style="display:flex; gap:8px; flex-wrap:wrap;">
            <button class="btn-primary" id="pdfCompressBtn">⚡ Compress PDF</button>
            <button class="btn-secondary" id="pdfClearBtn">✕ Clear</button>
          </div>
        </div>

        <!-- Result -->
        <div id="pdfResult" hidden style="margin-top:16px;">
          <div class="feature-card" style="border-color: #bbf7d0; background: #f0fdf4;">
            <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px;">
              <div>
                <p class="heading-md" style="color:#166534;">✅ PDF Compressed!</p>
                <p class="body-md" style="color:#166534; margin-top:4px;" id="pdfSavingSummary"></p>
              </div>
              <button class="btn-primary" id="pdfDownloadBtn" style="background:#166534;">⬇ Download PDF</button>
            </div>
          </div>
        </div>

        <!-- Warning -->
        <div class="feature-card" style="margin-top:16px; border-color: #fef9c3; background:#fefce8;">
          <p class="body-sm" style="color:#854d0e;">
            ⚠️ <strong>Note:</strong> PDF compression works by re-compressing embedded images. 
            PDFs that are mostly text will see minimal size reduction.
            For maximum results, use quality 40–60%.
          </p>
        </div>
      </div>

      <!-- RIGHT: Sidebar -->
      <div style="display:flex; flex-direction:column; gap:16px;">
        <div class="ad-slot ad-slot-sidebar">
          <span>Advertisement<br/>Sidebar ad</span>
        </div>
        <div class="feature-card">
          <p class="mono-eyebrow" style="margin-bottom:12px;">What gets compressed?</p>
          <ul style="list-style:none; display:flex; flex-direction:column; gap:8px;" class="body-md">
            <li>📷 Embedded JPEG images</li>
            <li>🖼️ Embedded PNG images</li>
            <li>✅ Preserves text & layout</li>
            <li>✅ Preserves links</li>
            <li>⚠️ Text-only PDFs: minimal effect</li>
          </ul>
        </div>
        <div class="feature-card">
          <p class="mono-eyebrow" style="margin-bottom:12px;">Privacy</p>
          <p class="body-md" style="color:var(--body);">
            Your PDF never leaves your device. Everything runs locally in your browser using PDF.js and Canvas API.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── FAQ ── -->
<section class="section-sm" style="border-top:1px solid var(--hairline);">
  <div class="container" style="max-width:720px;">
    <h2 class="heading-lg" style="margin-bottom:40px; text-align:center;">PDF Compression FAQ</h2>
    <div id="faq2">
      <div class="faq-item">
        <button class="faq-q">How much will my PDF shrink?</button>
        <div class="faq-a"><p>It depends on the PDF content. Image-heavy PDFs can shrink 50–80%. Text-only PDFs will see little change since text is already compact.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q">Is my PDF secure?</button>
        <div class="faq-a"><p>Yes. Your PDF is processed entirely in your browser. It is never uploaded to any server. You can even use this tool offline.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q">Will the text in my PDF remain readable?</button>
        <div class="faq-a"><p>Yes. Only embedded images are re-compressed. All text, fonts, links, and structure are preserved.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q">What quality setting should I use for PDFs?</button>
        <div class="faq-a"><p>For documents (reports, invoices), 60% works well. For photo-heavy PDFs, try 50%. For print quality, keep it at 80%+.</p></div>
      </div>
    </div>
  </div>
</section>

<!-- ── AD BOTTOM ── -->
<div class="container" style="margin-bottom:48px;">
  <div class="ad-slot ad-slot-banner">
    <span>Advertisement · AdSense banner</span>
  </div>
</div>

</Base>

<style>
.tool-grid { grid-template-columns: 1fr 300px; }
@media (max-width: 900px) { 
  .tool-grid { grid-template-columns: 1fr !important; gap: 24px; }
  .ad-slot-sidebar { width: 100% !important; }
}
@media (max-width: 768px) {
  .tool-grid { gap: 20px; }
}
@media (max-width: 640px) {
  .tool-grid { gap: 16px; }
  .ad-slot-sidebar { height: 100px !important; }
}
.faq-item { border-bottom: 1px solid var(--hairline); }
.faq-q {
  width: 100%; background: none; border: none; cursor: pointer;
  text-align: left; padding: 18px 0; font-size: 15px; font-weight: 500;
  color: var(--ink); font-family: var(--font-sans);
  display: flex; justify-content: space-between; align-items: center;
}
.faq-q::after { content: '+'; font-size: 20px; color: var(--mute); }
.faq-q.open::after { content: '−'; }
.faq-a { display: none; padding: 0 0 16px; color: var(--body); font-size: 14px; line-height: 22px; }
.faq-a.open { display: block; }
</style>

<!-- Load PDF.js from CDN -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js"></script>

<script>
// Set PDF.js worker
if (typeof pdfjsLib !== 'undefined') {
  pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
}

let pdfFile = null;
let compressedPdfBlob = null;

const pdfUploadZone   = document.getElementById('pdfUploadZone');
const pdfFileInput    = document.getElementById('pdfFileInput');
const pdfSettings     = document.getElementById('pdfSettings');
const pdfQualitySlider = document.getElementById('pdfQualitySlider');
const pdfQualityValue  = document.getElementById('pdfQualityValue');
const pdfCompressBtn  = document.getElementById('pdfCompressBtn');
const pdfClearBtn     = document.getElementById('pdfClearBtn');
const pdfResult       = document.getElementById('pdfResult');
const pdfDownloadBtn  = document.getElementById('pdfDownloadBtn');
const pdfProgress     = document.getElementById('pdfProgress');
const pdfProgressBar  = document.getElementById('pdfProgressBar');
const pdfProgressText = document.getElementById('pdfProgressText');

pdfQualitySlider.addEventListener('input', () => {
  pdfQualityValue.textContent = pdfQualitySlider.value + '%';
});

// Drag & drop
pdfUploadZone.addEventListener('dragover', e => { e.preventDefault(); pdfUploadZone.classList.add('drag-over'); });
pdfUploadZone.addEventListener('dragleave', () => pdfUploadZone.classList.remove('drag-over'));
pdfUploadZone.addEventListener('drop', e => {
  e.preventDefault(); pdfUploadZone.classList.remove('drag-over');
  const f = e.dataTransfer.files[0];
  if (f && f.type === 'application/pdf') loadPdf(f);
});
pdfUploadZone.addEventListener('click', e => { if (!e.target.closest('button')) pdfFileInput.click(); });
pdfFileInput.addEventListener('change', () => { if (pdfFileInput.files[0]) loadPdf(pdfFileInput.files[0]); });

function loadPdf(file) {
  pdfFile = file;
  document.getElementById('pdfFileName').textContent = file.name;
  document.getElementById('pdfOrigSize').textContent = 'Original: ' + formatBytes(file.size);
  document.getElementById('pdfOrigBadge').textContent = formatBytes(file.size);
  pdfSettings.removeAttribute('hidden');
  pdfResult.setAttribute('hidden', '');
}

pdfClearBtn.addEventListener('click', () => {
  pdfFile = null; compressedPdfBlob = null;
  pdfFileInput.value = '';
  pdfSettings.setAttribute('hidden', '');
  pdfResult.setAttribute('hidden', '');
  pdfProgress.setAttribute('hidden', '');
  pdfProgressBar.style.width = '0%';
});

pdfCompressBtn.addEventListener('click', async () => {
  if (!pdfFile) return;
  if (typeof pdfjsLib === 'undefined') {
    alert('PDF library not loaded. Please check your internet connection.');
    return;
  }

  const quality = parseInt(pdfQualitySlider.value) / 100;
  pdfCompressBtn.disabled = true;
  pdfCompressBtn.innerHTML = '<span class="spinner"></span> Processing…';
  pdfProgress.removeAttribute('hidden');
  pdfResult.setAttribute('hidden', '');

  try {
    const arrayBuffer = await pdfFile.arrayBuffer();
    const pdfDoc = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
    const numPages = pdfDoc.numPages;

    // We'll render each page to canvas and collect as JPEG data URLs
    // Then build a new PDF using a simple approach
    const pageDataUrls = [];

    for (let i = 1; i <= numPages; i++) {
      pdfProgressText.textContent = `Rendering page ${i} of ${numPages}…`;
      pdfProgressBar.style.width = `${Math.round((i / numPages) * 70)}%`;

      const page = await pdfDoc.getPage(i);
      const viewport = page.getViewport({ scale: 1.5 }); // scale for quality

      const canvas = document.createElement('canvas');
      canvas.width = viewport.width;
      canvas.height = viewport.height;
      const ctx = canvas.getContext('2d');

      await page.render({ canvasContext: ctx, viewport }).promise;
      const dataUrl = canvas.toDataURL('image/jpeg', quality);
      pageDataUrls.push({ dataUrl, width: viewport.width, height: viewport.height });
    }

    pdfProgressText.textContent = 'Building compressed PDF…';
    pdfProgressBar.style.width = '90%';

    // Build minimal PDF manually
    compressedPdfBlob = await buildPdfFromImages(pageDataUrls);

    pdfProgressBar.style.width = '100%';
    pdfProgressText.textContent = 'Done!';

    const saving = Math.round((1 - compressedPdfBlob.size / pdfFile.size) * 100);
    document.getElementById('pdfSavingSummary').textContent =
      `${formatBytes(pdfFile.size)} → ${formatBytes(compressedPdfBlob.size)}  (${saving > 0 ? saving + '% smaller' : 'similar size'})`;
    pdfResult.removeAttribute('hidden');

  } catch(e) {
    console.error(e);
    alert('Compression failed: ' + e.message + '\n\nNote: Some encrypted or complex PDFs may not be supported.');
    pdfProgress.setAttribute('hidden', '');
  }

  pdfCompressBtn.disabled = false;
  pdfCompressBtn.innerHTML = '⚡ Compress PDF';
});

pdfDownloadBtn.addEventListener('click', () => {
  if (!compressedPdfBlob) return;
  const a = document.createElement('a');
  a.href = URL.createObjectURL(compressedPdfBlob);
  a.download = 'compressed_' + (pdfFile?.name || 'file.pdf');
  a.click();
});

// Build a PDF from JPEG images (manual minimal PDF structure)
async function buildPdfFromImages(pages) {
  // We use a jsPDF-like minimal approach: load jsPDF dynamically
  // Load jsPDF from CDN
  if (!window.jspdf) {
    await loadScript('https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js');
  }
  const { jsPDF } = window.jspdf;

  const first = pages[0];
  // Convert px to mm (96dpi → 25.4mm/inch)
  const pxToMm = px => px * 25.4 / 96;

  const doc = new jsPDF({
    orientation: first.width > first.height ? 'landscape' : 'portrait',
    unit: 'mm',
    format: [pxToMm(first.width), pxToMm(first.height)],
  });

  for (let i = 0; i < pages.length; i++) {
    if (i > 0) doc.addPage([pxToMm(pages[i].width), pxToMm(pages[i].height)],
      pages[i].width > pages[i].height ? 'landscape' : 'portrait');
    doc.addImage(pages[i].dataUrl, 'JPEG', 0, 0, pxToMm(pages[i].width), pxToMm(pages[i].height));
  }

  const pdfBytes = doc.output('arraybuffer');
  return new Blob([pdfBytes], { type: 'application/pdf' });
}

function loadScript(src) {
  return new Promise((res, rej) => {
    const s = document.createElement('script');
    s.src = src; s.onload = res; s.onerror = rej;
    document.head.appendChild(s);
  });
}

function formatBytes(bytes) {
  if (bytes < 1024) return bytes + ' B';
  if (bytes < 1024*1024) return (bytes/1024).toFixed(1) + ' KB';
  return (bytes/(1024*1024)).toFixed(2) + ' MB';
}

// FAQ
document.querySelectorAll('.faq-q').forEach(btn => {
  btn.addEventListener('click', () => {
    btn.classList.toggle('open');
    btn.nextElementSibling.classList.toggle('open');
  });
});
</script>
