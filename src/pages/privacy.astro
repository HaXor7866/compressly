---
import Base from '../layouts/Base.astro';
---
<Base
  title="Privacy Policy – Compressly"
  description="Compressly privacy policy. We do not collect personal data. Files are processed in your browser."
  canonical="/privacy"
>
<section class="section">
  <div class="container" style="max-width:680px;">
    <h1 class="heading-lg" style="margin-bottom:8px;">Privacy Policy</h1>
    <p class="body-sm" style="color:var(--mute); margin-bottom:40px;">Last updated: June 2024</p>

    <div style="display:flex; flex-direction:column; gap:32px; color:var(--body);" class="body-lg">
      <div>
        <h2 class="heading-md" style="margin-bottom:12px; color:var(--ink);">Your files stay on your device</h2>
        <p>Compressly processes all files entirely within your browser using standard Web APIs (Canvas API, PDF.js). No files are ever uploaded to our servers.</p>
      </div>
      <div>
        <h2 class="heading-md" style="margin-bottom:12px; color:var(--ink);">Data we collect</h2>
        <p>We do not collect any personal information. We may use anonymous analytics (page views) to improve the tool. No cookies for tracking.</p>
      </div>
      <div>
        <h2 class="heading-md" style="margin-bottom:12px; color:var(--ink);">Advertising</h2>
        <p>We use Google AdSense to display ads. Google may use cookies for personalized advertising. You can opt out via Google's ad settings.</p>
      </div>
      <div>
        <h2 class="heading-md" style="margin-bottom:12px; color:var(--ink);">Contact</h2>
        <p>Questions? Email us at privacy@compressly.app</p>
      </div>
    </div>
  </div>
</section>
</Base>
