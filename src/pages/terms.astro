---
import Base from '../layouts/Base.astro';
---
<Base
  title="Terms & Conditions — Compressly"
  description="Terms and conditions for using Compressly. Read our user terms for privacy, acceptable use, and liability disclaimers."
  canonical="/terms"
  keywords="terms, terms and conditions, compressly terms"
>

<section class="section">
  <div class="container" style="max-width:880px;">
    <p class="mono-eyebrow">Legal</p>
    <h1 class="heading-lg" style="margin-bottom:12px;">Terms & Conditions</h1>
    <div class="body-md" style="color:var(--body); display:flex; flex-direction:column; gap:12px;">
      <p>Welcome to Compressly. By using our website and services you agree to these Terms & Conditions. Please read them carefully.</p>
      <h3>Use of Service</h3>
      <p>Compressly provides a browser-based file compression utility. You agree to use the service only for lawful purposes and not to upload content that violates third-party rights.</p>
      <h3>Privacy</h3>
      <p>Your files are processed locally in the browser and are not uploaded to our servers. See our Privacy Policy for full details.</p>
      <h3>Limitation of Liability</h3>
      <p>Compressly is provided as-is. We disclaim liability for indirect or consequential damages. Always keep backups of your original files.</p>
      <h3>Contact</h3>
      <p>Questions about these terms can be sent to <a href="mailto:hello@compressly.app">hello@compressly.app</a>.</p>
    </div>
  </div>
</section>

</Base>
